<Window x:Class="Connexion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Connexion"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    
    <StackPanel Margin="20">
        <Label Content="Nom d'utilisateur"/>
        <TextBox Text="{Binding Credentials.NomUtilisateur, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,8"/>
        <Label Content="Mot de passe"/>
        <PasswordBox x:Name="PwdBox"
                     PasswordChanged="PwdBox_Changed"
                     Margin="0,0,0,8"/>
        <CheckBox Content="Se souvenir de moi"
                  IsChecked="{Binding Credentials.SeSouvenir}"
                  Margin="0,0,0,12"/>
        <Button Content="Se connecter"
                Command="{Binding ConnexionCommand}"
                Margin="0,0,0,10"/>
        <TextBlock Text="{Binding Credentials.Message}"
                   FontWeight="Bold"/>
    </StackPanel>
</Window>
